[Unit]
Description=Ziptron Telegram bot
After=network-online.target
Wants=network-online.target
StartLimitIntervalSec=0
[Service]
WorkingDirectory=/opt/ziptronbot
ExecStart=/usr/bin/php /opt/ziptronbot/bot-daemon.php
Restart=always
RestartSec=3
TimeoutStopSec=10
KillMode=mixed
[Install]
WantedBy=multi-user.target
